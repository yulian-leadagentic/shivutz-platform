# ─── MySQL ───────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── RabbitMQ ────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SERVICE_JWT_SECRET=change_this_internal_service_secret

# ─── Auth Service ────────────────────────────────────────
AUTH_DB_NAME=auth_db
AUTH_SERVICE_URL=http://auth:3001

# ─── User-Org Service ────────────────────────────────────
ORG_DB_NAME=org_db
USER_ORG_SERVICE_URL=http://user-org:3002

# ─── Worker Service ──────────────────────────────────────
WORKER_DB_NAME=worker_db
WORKER_SERVICE_URL=http://worker:3003

# ─── Job-Match Service ───────────────────────────────────
JOB_DB_NAME=job_db
JOB_MATCH_SERVICE_URL=http://job-match:3004
MATCH_CACHE_TTL_SECONDS=300

# ─── Deal Service ────────────────────────────────────────
DEAL_DB_NAME=deal_db
DEAL_SERVICE_URL=http://deal:3005

# ─── Notification Service ────────────────────────────────
NOTIF_DB_NAME=notif_db
NOTIFICATION_SERVICE_URL=http://notification:3006
SENDGRID_API_KEY=SG.changeme
SENDGRID_FROM_EMAIL=noreply@shivutz-platform.co.il
SENDGRID_FROM_NAME=Shivutz Platform

# ─── Admin Service ───────────────────────────────────────
ADMIN_SERVICE_URL=http://admin:3007

# ─── Gateway ─────────────────────────────────────────────
GATEWAY_PORT=3000
RATE_LIMIT_ANON=30
RATE_LIMIT_USER=200
RATE_LIMIT_ADMIN=500
